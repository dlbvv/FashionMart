@page "/orders"
@page "/orders/{Id:int?}"
@rendermode InteractiveServer
@inject IOrderService OrderService
@inject ICurrentUserService CurrentUser

<PageTitle>Мои заказы — FashionMart</PageTitle>

<h1 class="mb-4"><i class="bi bi-receipt"></i> Мои заказы</h1>

@if (orders == null)
{
    <p><em>Загрузка...</em></p>
}
else if (!orders.Any())
{
    <div class="alert alert-info">Заказов пока нет. <a href="/products">Начать покупки</a>.</div>
}
else
{
    @foreach (var order in orders)
    {
        <div class="card mb-3 @(Id == order.Id ? "border-primary" : "")">
            <div class="card-header d-flex justify-content-between">
                <div>
                    <strong>Заказ #@order.Id</strong> от @order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </div>
                <span class="badge bg-@GetBadgeColor(order.Status)">@order.Status</span>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Адрес доставки:</strong> @order.ShippingAddress</p>
                <ul class="list-unstyled mb-2">
                    @foreach (var item in order.OrderItems)
                    {
                        <li>
                            @item.Product.Name × @item.Quantity = @((item.Quantity * item.UnitPrice).ToString("N0")) ₽
                        </li>
                    }
                </ul>
                <h5 class="text-primary mb-0">Итого: @order.TotalAmount.ToString("N0") ₽</h5>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int? Id { get; set; }
    private List<Models.Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        var customer = await CurrentUser.GetOrCreateGuestShopperAsync();
        orders = (await OrderService.GetByCustomerAsync(customer.Id)).ToList();
    }

    private string GetBadgeColor(Models.OrderStatus status) => status switch
    {
        Models.OrderStatus.Pending => "warning",
        Models.OrderStatus.Processing => "info",
        Models.OrderStatus.Shipped => "primary",
        Models.OrderStatus.Delivered => "success",
        Models.OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };
}
