@page "/"

<PageTitle>Главная — FashionMart</PageTitle>

<div class="row align-items-stretch g-4 mb-5">
    <div class="col-md-7">
        <div class="fm-hero text-white p-5 rounded-4 h-100 d-flex flex-column justify-content-center">
            <small class="text-uppercase" style="letter-spacing: 4px;">Новая коллекция</small>
            <h1 class="display-3 fw-bold mt-2 mb-3">Весна — лето 2024</h1>
            <p class="fs-5 mb-4">Свежие тренды, актуальные образы, лучшие бренды.</p>
            <a class="btn btn-light btn-lg align-self-start" href="/products">Смотреть коллекцию <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-md-5 d-flex flex-column gap-3">
        <div class="fm-card-feature flex-grow-1 d-flex align-items-center p-4">
            <i class="bi bi-percent fs-1 me-3 text-fm"></i>
            <div><h5 class="mb-1">Скидки до 50%</h5><small class="text-muted">На избранные позиции</small></div>
        </div>
        <div class="fm-card-feature flex-grow-1 d-flex align-items-center p-4">
            <i class="bi bi-arrow-repeat fs-1 me-3 text-fm"></i>
            <div><h5 class="mb-1">Возврат 30 дней</h5><small class="text-muted">Без вопросов</small></div>
        </div>
        <div class="fm-card-feature flex-grow-1 d-flex align-items-center p-4">
            <i class="bi bi-stars fs-1 me-3 text-fm"></i>
            <div><h5 class="mb-1">Подарок</h5><small class="text-muted">К заказу от 10 000 ₽</small></div>
        </div>
    </div>
</div>

<div class="text-center my-5">
    <h3 class="text-fm fw-light" style="letter-spacing: 3px;">— ВЫБИРАЙТЕ СВОЙ СТИЛЬ —</h3>
</div>